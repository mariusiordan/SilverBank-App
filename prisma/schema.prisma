datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String
  name     String
  accounts Account[]
}

model Account {
  id           Int           @id @default(autoincrement())
  iban         String        @unique
  balance      Float         @default(0)
  user         User          @relation(fields: [userId], references: [id])
  userId       Int
  transactions Transaction[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  type        String
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  account     Account  @relation(fields: [accountId], references: [id])
  accountId   Int
}

