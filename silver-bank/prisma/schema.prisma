datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String
  name     String
  accounts Account[]
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  password String
  name     String
  account  Account?  @relation(fields: [id], references: [userId]) // ❗ one account
}


model Transaction {
  id          Int      @id @default(autoincrement())
  type        String
  amount      Float
  description String?
  createdAt   DateTime @default(now())
  account     Account  @relation(fields: [accountId], references: [id])
  accountId   Int
}

